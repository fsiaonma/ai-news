# Dependencies
node_modules/

# IDE / local tooling
.agents/
.cursor/
.DS_Store

# 旧 VitePress 目录（已迁移至 website/，忽略残留 cache）
docs/

# VitePress build output
website/.vitepress/dist/
website/.vitepress/cache/

# ── 新闻：源文件在 news/YYYY-MM/*.md（需提交）
#    构建时 sync-news.mjs 复制到 website/news/
website/news/

# ── 教程：源文件在 course/*.md（需提交，与 news/ 同级）
#    构建时 sync-course.mjs 复制到 website/course/
website/course/

# 首页与侧栏由 sync 脚本生成
website/index.md
website/.vitepress/sidebar.generated.mjs
website/.vitepress/sidebar.course.mjs

# ── 关于我们：源文件在 about/（需提交）
#    构建时 sync-about.mjs 复制到 website/about/ 与 website/public/about/
about/members.generated.json
website/about/
website/public/about/
